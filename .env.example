# Lead Intelligence Platform - Environment Variables
# Copy this file to .env and fill in the values

# ── Optional: AI enrichment ──────────────────────────────
# OpenAI API key for AI-powered data enrichment and summarisation
# OPENAI_API_KEY=sk-...

# ── Optional: Contact enrichment ─────────────────────────
# Hunter.io API key for finding professional email addresses
# HUNTER_API_KEY=...

# ── Optional: Company data ────────────────────────────────
# Clearbit API key for deep company intelligence
# CLEARBIT_API_KEY=...

# ── Database ──────────────────────────────────────────────
# Path for the SQLite database file (default: lead_intel.db)
# DATABASE_URL=sqlite:///lead_intel.db

# ── Research settings ─────────────────────────────────────
# Delay (seconds) between web requests to avoid rate-limiting (default: 1.5)
# REQUEST_DELAY=1.5

# ── Logging ───────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
